    {
      "parameters": {
        "jsCode": "// Claude cavabından JSON çıxar\nconst raw = $input.first().json.content[0].text;\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('Claude cavabı JSON formatında deyil: ' + raw);\n}\nreturn [{ json: parsed }];"
      },
