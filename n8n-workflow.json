    {
      "parameters": {
        "jsCode": "const matches = $input.all().map(item => item.json);\nconst original = $('POST /products').first().json;\n\nlet matchText = \"Uyğun təklif tapılmadı.\";\nif (matches.length > 0) {\n  const top = matches[0];\n  matchText = matches.slice(0, 3).map(m => \n    `• ${m.name} — ${m.price_azn} AZN (bənzərlik: ${Math.round(m.similarity_score * 100)}%, ID: ${m.product_id})`\n  ).join(\"\\n\");\n  matchText += `\\n\\n💡 Təklif etmək üçün: /trade-offer məhsul ID-lərinizi (${original.id} və ${top.product_id}) admin panelinə göndərin.`;\n}\n\nreturn [{\n  json: {\n    product_name: original.name,\n    product_price: original.price_azn,\n    match_summary: matchText\n  }\n}];"
      },
